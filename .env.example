# Copy to .env for local preview (optional)
# Public env vars are embedded at build time on Vercel.

# --- Python makale üretimi (scripts/generate_post.py) — Astro build bunu kullanmaz ---
# Anthropic Console: https://console.anthropic.com/ → API Keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional blog ads only (Unutma app has no ads). Leave false unless you enable AdSense later.
PUBLIC_ADSENSE_ENABLED=false
PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
PUBLIC_ADSENSE_SLOT_IN_ARTICLE=XXXXXXXXXX
PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX

# Store URLs (defaults in components match com.mehmet.unutma)
PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.mehmet.unutma
PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/unutma-peace-of-mind/id6758889495
