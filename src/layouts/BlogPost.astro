---
import BaseLayout from './BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import AdSense from '../components/AdSense.astro';
import AppStoreBanner from '../components/AppStoreBanner.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { coverForSlug } from '../utils/covers';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, image } = post.data;
const heroImage = image ?? coverForSlug(post.slug);
const heroAlt = post.data.imageAlt ?? `${title} — article cover`;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    image={heroImage}
    article={true}
    publishedDate={pubDate}
  />

  <article class="mx-auto max-w-3xl px-4 py-8">
    <header class="mb-8">
      <img
        src={heroImage}
        alt={heroAlt}
        width={1200}
        height={630}
        loading="eager"
        decoding="async"
        class="mb-8 w-full rounded-xl object-cover aspect-[1200/630]"
      />
      <h1 class="brand-hero-title mb-3 text-3xl md:text-4xl lg:text-[2.35rem]">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
        {
          tags?.length ? (
            <div class="flex flex-wrap gap-2">
              {tags.map((tag: string) => (
                <a
                  href={`/blog/tags/${encodeURIComponent(tag)}/`}
                  class="rounded bg-indigo-100 px-2 py-0.5 text-xs text-indigo-700 hover:bg-indigo-200"
                >
                  {tag}
                </a>
              ))}
            </div>
          ) : null
        }
      </div>
    </header>

    <AdSense placement="header" />

    <div
      class="prose prose-lg max-w-none prose-a:text-brand prose-strong:text-gray-900"
    >
      <slot />
    </div>

    <AdSense placement="in-article" />

    <AppStoreBanner />

    <ShareButtons
      title={title}
      url={Astro.url.pathname}
      description={description}
    />

    <AdSense placement="footer" />
  </article>
</BaseLayout>
