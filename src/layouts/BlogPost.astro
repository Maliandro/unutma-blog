---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import AdSense from '../components/AdSense.astro';
import AppStoreBanner from '../components/AppStoreBanner.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { coverForSlug } from '../utils/covers';
import type { CollectionEntry } from 'astro:content';
import { DATE_LOCALE } from '../i18n/locales';
import { t } from '../i18n/ui';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
  readingMinutes: number;
}

const { post, headings, readingMinutes } = Astro.props;
const bp = t().blogPost;

const { title, description, pubDate, tags, image } = post.data;
const heroImage = image ?? coverForSlug(post.slug);
const heroAlt = post.data.imageAlt ?? `${title} — article cover`;

const toc = headings.filter((h) => h.depth === 2 && h.slug);
const showToc = toc.length >= 2;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={title}
    description={description}
    image={heroImage}
    article={true}
    publishedDate={pubDate}
  />

  <div
    id="reading-progress-track"
    class="pointer-events-none fixed left-0 right-0 top-0 z-[45] h-1 bg-gray-200/80 dark:bg-gray-800/80"
    aria-hidden="true"
  >
    <div
      id="reading-progress-bar"
      class="h-full w-0 bg-gradient-to-r from-brand to-peace dark:from-indigo-400 dark:to-emerald-500"
    >
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-8">
    <div
      class:list={[
        'lg:grid lg:items-start lg:gap-10 xl:gap-12',
        showToc ? 'lg:grid-cols-[minmax(0,42rem)_13.5rem]' : '',
      ]}
    >
      <article class:list={['min-w-0 max-w-3xl', showToc ? '' : 'mx-auto']}>
        <header class="mb-8">
          <div
            class="mb-8 overflow-hidden rounded-xl bg-gray-100 ring-1 ring-black/[0.06] dark:bg-gray-800/80 dark:ring-white/10"
          >
            <img
              src={heroImage}
              alt={heroAlt}
              width={1200}
              height={630}
              loading="eager"
              decoding="async"
              class="aspect-[1200/630] w-full object-cover object-center"
            />
          </div>
          <h1 class="brand-hero-title mb-3 text-3xl md:text-4xl lg:text-[2.35rem]">
            {title}
          </h1>
          <div
            class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 dark:text-gray-400"
          >
            <time datetime={pubDate.toISOString()}>
              {
                pubDate.toLocaleDateString(DATE_LOCALE, {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })
              }
            </time>
            <span class="text-gray-300 dark:text-gray-600" aria-hidden="true">·</span>
            <span title="Estimated reading time">
              ~{readingMinutes} {bp.minRead}
            </span>
            {
              tags?.length ? (
                <>
                  <span class="hidden sm:inline text-gray-300 dark:text-gray-600" aria-hidden="true">
                    ·
                  </span>
                  <div class="flex w-full flex-wrap gap-2 sm:w-auto">
                    {tags.map((tag: string) => (
                      <a
                        href={`/blog/tags/${encodeURIComponent(tag)}/`}
                        class="rounded bg-indigo-100 px-2 py-0.5 text-xs text-indigo-700 hover:bg-indigo-200 dark:bg-indigo-950/80 dark:text-indigo-300 dark:hover:bg-indigo-900"
                      >
                        {tag}
                      </a>
                    ))}
                  </div>
                </>
              ) : null
            }
          </div>
        </header>

        {
          showToc && (
            <details class="mb-8 rounded-xl border border-gray-200 bg-gray-50/80 p-4 dark:border-gray-700 dark:bg-gray-900/50 lg:hidden">
              <summary class="cursor-pointer font-semibold text-gray-900 dark:text-gray-100">
                {bp.tocTitle}
              </summary>
              <nav class="mt-3 border-t border-gray-200 pt-3 dark:border-gray-700" aria-label={bp.tocTitle}>
                <ol class="space-y-2 text-sm">
                  {toc.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class="text-brand hover:underline dark:text-indigo-400"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            </details>
          )
        }

        <AdSense placement="header" />

        <div
          id="article-content"
          class="prose prose-lg max-w-none dark:prose-invert prose-headings:scroll-mt-28 prose-headings:text-gray-900 dark:prose-headings:text-gray-50 prose-h2:font-display prose-h3:font-display prose-a:text-brand prose-strong:text-gray-900 dark:prose-strong:text-gray-100 prose-img:rounded-xl prose-img:ring-1 prose-img:ring-black/10 dark:prose-img:ring-white/10"
        >
          <slot />
        </div>

        <AdSense placement="in-article" />

        <AppStoreBanner />

        <ShareButtons
          title={title}
          url={Astro.url.pathname}
          description={description}
        />

        <AdSense placement="footer" />
      </article>

      {
        showToc && (
          <aside
            class="sticky top-28 mt-2 hidden min-w-0 max-h-[calc(100vh-8rem)] overflow-y-auto pb-8 lg:block"
            aria-label={bp.tocTitle}
          >
            <p class="font-display text-sm font-semibold text-gray-900 dark:text-gray-100">
              {bp.tocTitle}
            </p>
            <nav class="mt-3 border-l-2 border-indigo-200 pl-4 dark:border-indigo-900/80">
              <ol class="space-y-2.5 text-sm">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="text-gray-600 transition hover:text-brand dark:text-gray-400 dark:hover:text-indigo-400"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          </aside>
        )
      }
    </div>
  </div>

  <script is:inline>
    (function () {
      var track = document.getElementById('reading-progress-track');
      var bar = document.getElementById('reading-progress-bar');
      var article = document.getElementById('article-content');
      if (!track || !bar || !article) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        track.style.display = 'none';
        return;
      }
      function update() {
        var y = window.pageYOffset;
        var top = article.getBoundingClientRect().top + y;
        var h = article.offsetHeight;
        var vh = window.innerHeight;
        var denom = Math.max(h - vh, 1);
        var p = (y - top + vh * 0.15) / denom;
        p = Math.max(0, Math.min(1, p));
        bar.style.width = p * 100 + '%';
      }
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    })();
  </script>
</BaseLayout>
