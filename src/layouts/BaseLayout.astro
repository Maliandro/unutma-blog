---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  /** When no slot head, optional defaults for minimal pages */
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/unutma-icon.png" sizes="512x512" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/unutma-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    {title && !Astro.slots.has('head') && (
      <>
        <title>{title}</title>
        {description && <meta name="description" content={description} />}
      </>
    )}
    <slot name="head" />
    {
      adsenseClient && import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true' && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body class="min-h-screen bg-white font-sans text-gray-800 subpixel-antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
