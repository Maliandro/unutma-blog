---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import BlogCard from '../components/BlogCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import StoreBadgeRow from '../components/StoreBadgeRow.astro';
import { withBase } from '../utils/site';
import { coverForSlug } from '../utils/covers';
import { getCollection } from 'astro:content';

const all = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) =>
    Number(Boolean(b.data.featured)) - Number(Boolean(a.data.featured)) ||
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Showcase/featured post becomes the big hero; everything else fills the side rail.
const hero = sorted.find((p) => p.data.featured) ?? sorted[0];
const rest = sorted.filter((p) => p.slug !== hero?.slug);
const sideList = rest.slice(0, 5);
const moreGrid = rest.slice(5, 8);

const heroCover = hero
  ? withBase(hero.data.image ?? coverForSlug(hero.slug))
  : '';
const heroCoverAlt = hero?.data.imageAlt ?? hero?.data.title ?? '';
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Organize Your Life, Your Way"
    description="Unutma Blog — practical guides on productivity, privacy-first apps, journaling, and routines. Download Unutma: offline, private, free."
  />

  <section
    class="relative overflow-hidden border-b border-indigo-100/80 bg-gradient-to-b from-indigo-50/95 via-emerald-50/30 to-white"
  >
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(99,102,241,0.12),transparent)]"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-5xl px-4 py-16 md:py-24">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <img
          src={withBase('/unutma-icon.png')}
          width="96"
          height="96"
          alt="Unutma"
          class="h-20 w-20 shrink-0 rounded-[22%] shadow-brand ring-1 ring-black/[0.07] sm:h-24 sm:w-24"
          decoding="async"
        />
        <div class="min-w-0 flex-1">
          <p class="brand-wordmark brand-wordmark-lg">Unutma</p>
          <p class="brand-peace mt-2 text-base md:text-lg">
            Peace of mind, on your phone
          </p>
          <h1 class="brand-hero-title mt-5 max-w-3xl text-4xl md:text-5xl lg:text-[3.15rem]">
            Organize your life, your way
          </h1>
          <p class="mt-4 max-w-2xl text-lg font-normal leading-relaxed text-gray-600">
            Offline-first lists, journal, routines, vault, and more — all on your
            phone. No account required. This blog shares tips that pair perfectly
            with a calmer digital life.
          </p>
        </div>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <StoreBadgeRow />
        <a
          href={withBase('/blog')}
          class="inline-flex items-center rounded-lg px-4 py-3 font-medium text-brand hover:underline"
        >
          Read the blog →
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    {
      hero ? (
        <div class="grid gap-10 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
          {/* Big featured hero — the showcase / catalog article */}
          <article class="group">
            <a
              href={withBase(`/blog/${hero.slug}/`)}
              class="relative block aspect-[1200/700] w-full overflow-hidden rounded-2xl border border-gray-100 bg-gray-100 shadow-sm"
            >
              <img
                src={heroCover}
                alt={heroCoverAlt}
                width="1200"
                height="700"
                decoding="async"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
              />
              <span class="absolute left-4 top-4 rounded-full bg-brand px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow">
                Featured
              </span>
            </a>
            <time
              class="mt-5 block text-xs font-medium uppercase tracking-wide text-gray-500"
              datetime={hero.data.pubDate.toISOString()}
            >
              {fmtDate(hero.data.pubDate)}
            </time>
            <h2 class="font-display mt-2 text-2xl font-bold tracking-tight text-gray-900 md:text-3xl">
              <a
                href={withBase(`/blog/${hero.slug}/`)}
                class="hover:text-brand focus:outline-none"
              >
                {hero.data.title}
              </a>
            </h2>
            <p class="mt-3 max-w-2xl text-lg leading-relaxed text-gray-600">
              {hero.data.description}
            </p>
            <a
              href={withBase(`/blog/${hero.slug}/`)}
              class="mt-5 inline-flex items-center rounded-lg bg-brand px-5 py-3 font-semibold text-white shadow-sm transition hover:opacity-90"
            >
              See the full app guide →
            </a>
          </article>

          {/* Side rail — other articles */}
          <aside class="lg:border-l lg:border-gray-100 lg:pl-10">
            <h3 class="section-title text-xl">More articles</h3>
            <ul class="mt-6 divide-y divide-gray-100">
              {sideList.map((post) => (
                <li class="group py-4 first:pt-0">
                  <a href={withBase(`/blog/${post.slug}/`)} class="flex gap-4">
                    <img
                      src={withBase(post.data.image ?? coverForSlug(post.slug))}
                      alt={post.data.imageAlt ?? post.data.title}
                      width="120"
                      height="80"
                      loading="lazy"
                      decoding="async"
                      class="h-16 w-24 shrink-0 rounded-lg border border-gray-100 object-cover"
                    />
                    <div class="min-w-0">
                      <time
                        class="text-[11px] font-medium uppercase tracking-wide text-gray-400"
                        datetime={post.data.pubDate.toISOString()}
                      >
                        {fmtDate(post.data.pubDate)}
                      </time>
                      <h4 class="font-display mt-0.5 text-sm font-semibold leading-snug text-gray-900 line-clamp-2 group-hover:text-brand">
                        {post.data.title}
                      </h4>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
            <a
              href={withBase('/blog')}
              class="mt-6 inline-flex font-medium text-brand hover:underline"
            >
              View all posts →
            </a>
          </aside>
        </div>
      ) : (
        <p class="text-gray-500">
          No posts yet — add Markdown files under{' '}
          <code class="rounded bg-gray-100 px-1 text-sm">src/content/blog/</code>
          {' '}or run the Python generator.
        </p>
      )
    }

    {
      moreGrid.length ? (
        <div class="mt-16">
          <h3 class="section-title text-2xl">Latest articles</h3>
          <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {moreGrid.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        </div>
      ) : null
    }
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-16">
    <h2 class="section-title text-3xl md:text-[2rem]">Why Unutma?</h2>
    <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-gray-100 p-6">
        <h3 class="font-display text-lg font-semibold text-gray-900">Offline-first</h3>
        <p class="mt-2 text-sm text-gray-600">
          Core features work without a constant internet connection.
        </p>
      </div>
      <div class="rounded-xl border border-gray-100 p-6">
        <h3 class="font-display text-lg font-semibold text-gray-900">Private</h3>
        <p class="mt-2 text-sm text-gray-600">
          Your notes and lists stay on your device — not on our servers.
        </p>
      </div>
      <div class="rounded-xl border border-gray-100 p-6">
        <h3 class="font-display text-lg font-semibold text-gray-900">Free to start</h3>
        <p class="mt-2 text-sm text-gray-600">
          Get organized without a subscription wall for the essentials.
        </p>
      </div>
      <div class="rounded-xl border border-gray-100 p-6">
        <h3 class="font-display text-lg font-semibold text-gray-900">Multi-language</h3>
        <p class="mt-2 text-sm text-gray-600">
          Use the app in the language that fits your day.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-20">
    <NewsletterForm />
  </section>
</BaseLayout>
