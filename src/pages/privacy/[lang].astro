---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import LegalDocument from '../../components/LegalDocument.astro';
import {
  getLegal,
  isLegalLang,
  LEGAL_LANGUAGES,
  type LegalLang,
} from '../../data/legal';

export function getStaticPaths() {
  return LEGAL_LANGUAGES.filter(({ code }) => code !== 'en').map(({ code }) => ({
    params: { lang: code },
  }));
}

const langParam = Astro.params.lang;
if (!isLegalLang(langParam)) {
  return Astro.redirect('/privacy');
}
const lang = langParam as LegalLang;
const legal = getLegal(lang);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={legal.privacyTitle}
    description={`${legal.privacyTitle} — Unutma`}
  />

  <article
    class="prose prose-lg mx-auto max-w-3xl px-4 py-12 prose-a:text-brand prose-strong:text-gray-900"
  >
    <LegalDocument kind="privacy" lang={lang} legal={legal} />
  </article>
</BaseLayout>
