---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import { LOCALES, type Locale } from '../../i18n/locales';
import { href } from '../../i18n/paths';
import { t } from '../../i18n/ui';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const u = t(locale).about;
---

<BaseLayout locale={locale}>
  <SEOHead
    slot="head"
    title={u.seoTitle}
    description={u.seoDesc}
    locale={locale}
  />

  <article
    class="prose prose-lg mx-auto max-w-3xl px-4 py-12 dark:prose-invert prose-a:text-brand prose-strong:text-gray-900 dark:prose-strong:text-gray-100"
  >
    <h1>{u.h1}</h1>
    <p>{u.p1}</p>
    <h2>{u.h2}</h2>
    <p>{u.p2}</p>
    <p>{u.p3}</p>
    <p>
      <a href={href(locale, '/')}>{t(locale).nav.home}</a>
      {' · '}
      <a href={href(locale, '/blog')}>{t(locale).nav.blog}</a>
      {' · '}
      <a href={href(locale, '/privacy')}>{t(locale).footer.privacy}</a>
    </p>
  </article>
</BaseLayout>
