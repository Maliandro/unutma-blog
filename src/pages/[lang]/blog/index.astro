---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/SEOHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { LOCALES, type Locale } from '../../../i18n/locales';
import { href, postsPerPage } from '../../../i18n/paths';
import { t } from '../../../i18n/ui';

export const prerender = true;

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const u = t(locale).blog;

const POSTS_PER_PAGE = postsPerPage();
const all = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const totalPages = Math.max(1, Math.ceil(sorted.length / POSTS_PER_PAGE));
const posts = sorted.slice(0, POSTS_PER_PAGE);
---

<BaseLayout locale={locale}>
  <SEOHead
    slot="head"
    title={u.seoTitle}
    description={u.seoDesc}
    locale={locale}
  />

  <div class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="section-title text-4xl md:text-[2.35rem]">{u.title}</h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">{u.sub}</p>
    {
      u.enNote ? (
        <p class="mt-2 text-sm text-amber-800 dark:text-amber-200/90">{u.enNote}</p>
      ) : null
    }

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <BlogCard post={post} locale={locale} />)}
    </div>

    {
      totalPages > 1 && (
        <nav
          class="mt-12 flex items-center justify-center gap-4"
          aria-label="Pagination"
        >
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {u.pageOf} 1 / {totalPages}
          </span>
          <a
            href={href(locale, '/blog/page/2')}
            class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white hover:bg-brand-dark"
          >
            {u.next}
          </a>
        </nav>
      )
    }
  </div>
</BaseLayout>
