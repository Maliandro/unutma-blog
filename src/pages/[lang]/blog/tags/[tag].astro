---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SEOHead from '../../../../components/SEOHead.astro';
import BlogCard from '../../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { LOCALES, type Locale } from '../../../../i18n/locales';
import { href } from '../../../../i18n/paths';
import { t } from '../../../../i18n/ui';

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const post of all) {
    for (const t of post.data.tags ?? []) {
      tagSet.add(t);
    }
  }

  const paths: {
    params: { lang: string; tag: string };
    props: { tag: string; posts: typeof all };
  }[] = [];

  for (const locale of LOCALES) {
    for (const tag of tagSet) {
      const posts = all
        .filter((p) => (p.data.tags ?? []).includes(tag))
        .sort(
          (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
        );
      paths.push({
        params: { lang: locale, tag },
        props: { tag, posts },
      });
    }
  }
  return paths;
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { lang } = Astro.params;
const locale = lang as Locale;
const u = t(locale).blog;

const { tag, posts } = Astro.props;
---

<BaseLayout locale={locale}>
  <SEOHead
    slot="head"
    title={`${u.tagSeo}: ${tag}`}
    description={`${u.tagSeo} “${tag}”.`}
    locale={locale}
  />

  <div class="mx-auto max-w-5xl px-4 py-12">
    <a
      href={href(locale, '/blog')}
      class="text-sm font-medium text-brand hover:underline dark:text-indigo-400"
      >{u.tagAll}</a
    >
    <h1 class="mt-4 text-3xl font-bold text-gray-900 dark:text-gray-100">
      {tag}
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">
      {posts.length} {u.tagCount}
    </p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <BlogCard post={post} locale={locale} />)}
    </div>
  </div>
</BaseLayout>
