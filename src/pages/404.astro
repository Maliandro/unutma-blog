---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Page not found"
    description="The page you are looking for does not exist."
  />

  <div class="mx-auto max-w-lg px-4 py-24 text-center">
    <p class="text-6xl font-bold text-gray-200">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-gray-900">Page not found</h1>
    <p class="mt-2 text-gray-600">
      That link may be outdated or mistyped.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg bg-brand px-6 py-3 font-medium text-white hover:bg-brand-dark"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
