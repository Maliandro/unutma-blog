---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/SEOHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const post of all) {
    for (const t of post.data.tags ?? []) {
      tagSet.add(t);
    }
  }
  return [...tagSet].map((tag) => {
    const posts = all
      .filter((p) => (p.data.tags ?? []).includes(tag))
      .sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      );
    return {
      params: { tag },
      props: { tag, posts },
    };
  });
}

interface Props {
  tag: string;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { tag, posts } = Astro.props;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Tag: ${tag}`}
    description={`Unutma Blog posts tagged “${tag}”.`}
  />

  <div class="mx-auto max-w-5xl px-4 py-12">
    <a href="/blog" class="text-sm font-medium text-brand hover:underline"
      >← All posts</a
    >
    <h1 class="mt-4 text-3xl font-bold text-gray-900">
      Tag: <span class="text-brand">{tag}</span>
    </h1>
    <p class="mt-2 text-gray-600">{posts.length} article(s)</p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </div>
</BaseLayout>
