---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const POSTS_PER_PAGE = 12;

const all = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const totalPages = Math.max(1, Math.ceil(sorted.length / POSTS_PER_PAGE));
const posts = sorted.slice(0, POSTS_PER_PAGE);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Blog"
    description="Articles on productivity, privacy-first tools, journaling, routines, and organization — from the Unutma team."
  />

  <div class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="section-title text-4xl md:text-[2.35rem]">Blog</h1>
    <p class="mt-2 text-gray-600">
      All posts, newest first. Filter by tag from each card.
    </p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    {
      totalPages > 1 && (
        <nav
          class="mt-12 flex items-center justify-center gap-4"
          aria-label="Pagination"
        >
          <span class="text-sm text-gray-500">Page 1 of {totalPages}</span>
          <a
            href="/blog/page/2/"
            class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white hover:bg-brand-dark"
          >
            Next
          </a>
        </nav>
      )
    }
  </div>
</BaseLayout>
