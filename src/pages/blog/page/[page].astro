---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SEOHead from '../../../components/SEOHead.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { postsPerPage } from '../../../i18n/paths';
import { t } from '../../../i18n/ui';

export const prerender = true;

export async function getStaticPaths() {
  const POSTS_PER_PAGE = postsPerPage();
  const all = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = all.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  const totalPages = Math.max(1, Math.ceil(sorted.length / POSTS_PER_PAGE));
  if (totalPages <= 1) return [];

  const paths: {
    params: { page: string };
    props: {
      posts: typeof sorted;
      currentPage: number;
      totalPages: number;
    };
  }[] = [];

  for (let p = 2; p <= totalPages; p++) {
    const start = (p - 1) * POSTS_PER_PAGE;
    paths.push({
      params: { page: String(p) },
      props: {
        posts: sorted.slice(start, start + POSTS_PER_PAGE),
        currentPage: p,
        totalPages,
      },
    });
  }
  return paths;
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
  currentPage: number;
  totalPages: number;
}

const u = t().blog;

const { posts, currentPage, totalPages } = Astro.props;
const title = `${u.pageTitle} ${currentPage}`;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={title}
    description={`Unutma Blog — ${u.pageOf} ${currentPage} / ${totalPages}`}
  />

  <div class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="section-title text-3xl md:text-[2.35rem]">
      {u.pageTitle}
      {' '}
      {currentPage}
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">{u.older}</p>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    <nav
      class="mt-12 flex flex-wrap items-center justify-center gap-4"
      aria-label="Pagination"
    >
      {
        currentPage > 2 ? (
          <a
            href={`/blog/page/${currentPage - 1}/`}
            class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-800 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-800"
          >
            {u.prev}
          </a>
        ) : currentPage === 2 ? (
          <a
            href="/blog/"
            class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-800 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-800"
          >
            {u.prev}
          </a>
        ) : null
      }
      <span class="text-sm text-gray-500 dark:text-gray-400">
        {u.pageOf} {currentPage} / {totalPages}
      </span>
      {
        currentPage < totalPages && (
          <a
            href={`/blog/page/${currentPage + 1}/`}
            class="rounded-lg bg-brand px-4 py-2 text-sm font-medium text-white hover:bg-brand-dark"
          >
            {u.next}
          </a>
        )
      }
    </nav>
  </div>
</BaseLayout>
