---
/** Placeholder — connect to Mailchimp, Buttondown, or Formspree later */
---

<section class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center">
  <h2 class="section-title mb-2 text-xl md:text-2xl">Stay organized</h2>
  <p class="mb-6 text-gray-600">
    Get occasional tips on productivity and privacy-first apps. No spam.
  </p>
  <form
    class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row"
    method="post"
    action="#"
  >
    <label
      for="newsletter-email"
      class="sr-only"
      >Email</label
    >
    <input
      id="newsletter-email"
      name="email"
      type="email"
      required
      placeholder="you@example.com"
      class="flex-1 rounded-lg border border-gray-300 px-4 py-2 text-gray-900 placeholder:text-gray-400 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
      disabled
    />
    <button
      type="button"
      class="rounded-lg bg-brand px-6 py-2 font-medium text-white opacity-60"
      disabled
    >
      Coming soon
    </button>
  </form>
  <p class="mt-3 text-xs text-gray-500">
    Connect your email provider in <code class="rounded bg-gray-200 px-1"
      >NewsletterForm.astro</code
    > when ready.
  </p>
</section>
