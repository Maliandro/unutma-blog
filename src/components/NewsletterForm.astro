---
import { t } from '../i18n/ui';

const u = t().newsletter;
---

<section
  class="rounded-xl border border-gray-200 bg-gray-50 p-8 text-center dark:border-gray-700 dark:bg-gray-900/60"
>
  <h2 class="section-title mb-2 text-xl md:text-2xl">{u.title}</h2>
  <p class="mb-6 text-gray-600 dark:text-gray-400">{u.sub}</p>
  <form
    class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row"
    method="post"
    action="#"
    aria-describedby="newsletter-hint"
  >
    <label for="newsletter-email" class="sr-only">{u.email}</label>
    <input
      id="newsletter-email"
      name="email"
      type="email"
      required
      placeholder={u.placeholder}
      class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-2 text-gray-900 placeholder:text-gray-400 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30 dark:border-gray-600 dark:bg-gray-950 dark:text-gray-100 dark:placeholder:text-gray-500"
      disabled
      autocomplete="email"
    />
    <button
      type="button"
      class="rounded-lg bg-brand px-6 py-2 font-medium text-white opacity-75 dark:opacity-80"
      disabled
    >
      {u.btn}
    </button>
  </form>
  <p id="newsletter-hint" class="mt-3 text-xs text-gray-500 dark:text-gray-500">
    {u.hint}
  </p>
</section>
