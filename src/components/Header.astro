---
import type { Locale } from '../i18n/locales';
import { LOCALES } from '../i18n/locales';
import { href, switchLocale } from '../i18n/paths';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const pathname = Astro.url.pathname;
const u = t(locale);

const langLabel: Record<Locale, string> = {
  en: 'English',
  de: 'Deutsch',
  es: 'Español',
  it: 'Italiano',
  fr: 'Français',
  tr: 'Türkçe',
};

const nav = [
  { href: href(locale, '/'), label: u.nav.home, key: 'home' },
  { href: href(locale, '/blog'), label: u.nav.blog, key: 'blog' },
  { href: href(locale, '/about'), label: u.nav.about, key: 'about' },
];

function isActive(key: string): boolean {
  if (key === 'home') {
    return pathname === `/${locale}/` || pathname === `/${locale}`;
  }
  if (key === 'blog') {
    return pathname.includes(`/${locale}/blog`);
  }
  if (key === 'about') {
    return pathname.includes(`/${locale}/about`);
  }
  return false;
}
---

<header
  class="border-b border-gray-100/90 bg-white/85 shadow-brand-sm backdrop-blur-md dark:border-gray-800/90 dark:bg-gray-950/90"
>
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-4">
    <a
      href={href(locale, '/')}
      class="group flex items-center gap-3 rounded-lg outline-none ring-brand/0 transition hover:ring-2 focus-visible:ring-2 focus-visible:ring-brand/30"
    >
      <img
        src="/unutma-icon.png"
        width="40"
        height="40"
        alt=""
        class="h-9 w-9 rounded-[22%] shadow-md ring-1 ring-black/[0.06] transition group-hover:shadow-brand-sm dark:ring-white/10"
        decoding="async"
      />
      <span class="leading-tight">
        <span class="flex flex-wrap items-baseline gap-x-2 gap-y-0">
          <span class="brand-wordmark brand-wordmark-sm">Unutma</span>
          <span
            class="font-sans text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-gray-400 dark:text-gray-500"
          >
            {u.header.blog}
          </span>
        </span>
        <span class="brand-peace brand-peace-muted mt-0.5 block text-[0.68rem] md:text-xs">
          {u.header.peace}
        </span>
      </span>
    </a>
    <div class="flex flex-wrap items-center justify-end gap-3 sm:gap-4">
      <label class="sr-only" for="lang-select">{u.lang.label}</label>
      <select
        id="lang-select"
        class="rounded-lg border border-gray-200 bg-white px-2 py-1.5 text-xs font-medium text-gray-700 shadow-sm dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200"
      >
        {
          LOCALES.map((l) => (
            <option value={switchLocale(pathname, l)} selected={l === locale}>
              {langLabel[l]}
            </option>
          ))
        }
      </select>
      <button
        type="button"
        id="theme-toggle"
        class="rounded-lg border border-gray-200 bg-white p-2 text-gray-600 shadow-sm transition hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-amber-200 dark:hover:bg-gray-800"
        aria-label={u.theme.toggle}
        title={u.theme.toggle}
      >
        <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 3a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V4a1 1 0 0 1 1-1zm5.657 2.343a1 1 0 0 1 1.414 0l.707.707a1 1 0 1 1-1.414 1.414l-.707-.707a1 1 0 0 1 0-1.414zM18 11a1 1 0 1 1 0 2h-1a1 1 0 1 1 0-2h1zm-2.343 5.657a1 1 0 0 1 0 1.414l-.707.707a1 1 0 1 1-1.414-1.414l.707-.707a1 1 0 0 1 1.414 0zM12 20a1 1 0 0 1-1-1v-1a1 1 0 1 1 2 0v1a1 1 0 0 1-1 1zm-6.364-1.636a1 1 0 0 1 0-1.414l.707-.707a1 1 0 1 1 1.414 1.414l-.707.707a1 1 0 0 1-1.414 0zM6 13a1 1 0 1 1 0-2H5a1 1 0 1 1 0 2h1zm1.343-8.536a1 1 0 0 1 1.414 0l.707.707A1 1 0 0 1 8.05 6.585l-.707-.707a1 1 0 0 1 0-1.414zM12 8a4 4 0 1 1 0 8 4 4 0 0 1 0-8z"
          />
        </svg>
        <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"
          />
        </svg>
      </button>
      <nav class="flex w-full basis-full gap-4 sm:w-auto sm:basis-auto sm:gap-6" aria-label="Main">
        {
          nav.map(({ href: h, label, key }) => (
            <a
              href={h}
              class:list={[
                'text-sm font-medium transition hover:text-brand',
                isActive(key) ? 'text-brand' : 'text-gray-600 dark:text-gray-400',
              ]}
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var sel = document.getElementById('lang-select');
    if (!sel) return;
    sel.addEventListener('change', function () {
      window.location.href = sel.value;
    });
  })();
</script>
