---
const pathname = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-gray-100/90 bg-white/85 shadow-brand-sm backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a
      href="/"
      class="group flex items-center gap-3 rounded-lg outline-none ring-brand/0 transition hover:ring-2 focus-visible:ring-2 focus-visible:ring-brand/30"
    >
      <img
        src="/unutma-icon.png"
        width="40"
        height="40"
        alt=""
        class="h-9 w-9 rounded-[22%] shadow-md ring-1 ring-black/[0.06] transition group-hover:shadow-brand-sm"
        decoding="async"
      />
      <span class="leading-tight">
        <span class="flex flex-wrap items-baseline gap-x-2 gap-y-0">
          <span class="brand-wordmark brand-wordmark-sm">Unutma</span>
          <span
            class="font-sans text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-gray-400"
          >
            Blog
          </span>
        </span>
        <span class="brand-peace brand-peace-muted mt-0.5 block text-[0.68rem] md:text-xs">
          Peace of mind
        </span>
      </span>
    </a>
    <nav class="flex gap-6" aria-label="Main">
      {
        nav.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition hover:text-brand',
              pathname === href || (href !== '/' && pathname.startsWith(href))
                ? 'text-brand'
                : 'text-gray-600',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
