---
import { t } from '../i18n/ui';

const year = new Date().getFullYear();
const u = t();
const playStoreUrl =
  import.meta.env.PUBLIC_PLAY_STORE_URL ??
  'https://play.google.com/store/apps/details?id=com.mehmet.unutma';
const appStoreUrl =
  import.meta.env.PUBLIC_APP_STORE_URL ??
  'https://apps.apple.com/us/app/unutma-peace-of-mind/id6758889495';
---

<footer class="mt-16 border-t border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900/50">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <div>
        <p class="brand-wordmark brand-wordmark-sm text-left">Unutma</p>
        <p class="mt-1 max-w-sm text-sm text-gray-600 dark:text-gray-400">
          {u.footer.blurb}
        </p>
      </div>
      <div class="flex flex-col gap-4 text-sm">
        <a
          href="/privacy/"
          class="text-gray-600 hover:text-brand dark:text-gray-400 dark:hover:text-indigo-400"
          >{u.footer.privacy}</a
        >
        <a
          href={playStoreUrl}
          class="text-gray-600 hover:text-brand dark:text-gray-400 dark:hover:text-indigo-400"
          target="_blank"
          rel="noopener noreferrer">{u.footer.googlePlay}</a
        >
        <a
          href={appStoreUrl}
          class="text-gray-600 hover:text-brand dark:text-gray-400 dark:hover:text-indigo-400"
          target="_blank"
          rel="noopener noreferrer">{u.footer.appStore}</a
        >
      </div>
    </div>
    <p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-500">
      © {year} Unutma. {u.footer.rights}
    </p>
  </div>
</footer>
