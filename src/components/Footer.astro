---
import { t } from '../i18n/ui';

const year = new Date().getFullYear();
const u = t();
const nav = t().nav;
const playStoreUrl =
  import.meta.env.PUBLIC_PLAY_STORE_URL ??
  'https://play.google.com/store/apps/details?id=com.mehmet.unutma';
const appStoreUrl =
  import.meta.env.PUBLIC_APP_STORE_URL ??
  'https://apps.apple.com/us/app/unutma-peace-of-mind/id6758889495';
---

<footer class="mt-16 border-t border-gray-100 bg-gray-50 dark:border-gray-800 dark:bg-gray-900/50">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div>
        <p class="brand-wordmark brand-wordmark-sm text-left">Unutma</p>
        <p class="mt-1 max-w-sm text-sm text-gray-600 dark:text-gray-400">
          {u.footer.blurb}
        </p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
          {u.footer.explore}
        </p>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          <li>
            <a
              href="/"
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              >{nav.home}</a
            >
          </li>
          <li>
            <a
              href="/blog/"
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              >{nav.blog}</a
            >
          </li>
          <li>
            <a
              href="/blog/"
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              >{u.footer.allPosts}</a
            >
          </li>
          <li>
            <a
              href="/about/"
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              >{nav.about}</a
            >
          </li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
          {u.footer.legalApp}
        </p>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          <li>
            <a
              href="/privacy/"
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              >{u.footer.privacy}</a
            >
          </li>
          <li>
            <a
              href={playStoreUrl}
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              target="_blank"
              rel="noopener noreferrer">{u.footer.googlePlay}</a
            >
          </li>
          <li>
            <a
              href={appStoreUrl}
              class="text-gray-700 hover:text-brand dark:text-gray-300 dark:hover:text-indigo-400"
              target="_blank"
              rel="noopener noreferrer">{u.footer.appStore}</a
            >
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-10 text-center text-xs text-gray-500 dark:text-gray-500">
      © {year} Unutma. {u.footer.rights}
    </p>
  </div>
</footer>
