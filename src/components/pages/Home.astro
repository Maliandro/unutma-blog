---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import StoreBadgeRow from '../../components/StoreBadgeRow.astro';
import { getCollection } from 'astro:content';
import { t } from '../../i18n/ui';

const u = t().home;

const all = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = sorted.slice(0, 6);

const whyCards = [
  {
    border: 'border-l-indigo-500',
    iconBg: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-950/80 dark:text-indigo-300',
    title: u.f1t,
    body: u.f1d,
    icon: 'offline',
  },
  {
    border: 'border-l-emerald-600',
    iconBg: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300',
    title: u.f2t,
    body: u.f2d,
    icon: 'shield',
  },
  {
    border: 'border-l-violet-500',
    iconBg: 'bg-violet-100 text-violet-800 dark:bg-violet-950/60 dark:text-violet-300',
    title: u.f3t,
    body: u.f3d,
    icon: 'gift',
  },
  {
    border: 'border-l-cyan-600',
    iconBg: 'bg-cyan-100 text-cyan-900 dark:bg-cyan-950/50 dark:text-cyan-300',
    title: u.f4t,
    body: u.f4d,
    icon: 'globe',
  },
] as const;
---

<BaseLayout>
  <SEOHead slot="head" title={u.seoTitle} description={u.seoDesc} />

  <section
    class="relative overflow-hidden border-b border-indigo-100/80 bg-gradient-to-b from-indigo-50/95 via-emerald-50/30 to-white dark:border-indigo-900/40 dark:from-indigo-950/40 dark:via-emerald-950/20 dark:to-gray-950"
  >
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(99,102,241,0.12),transparent)] dark:bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(99,102,241,0.18),transparent)]"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-5xl px-4 py-16 md:py-24">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        <img
          src="/unutma-icon.png"
          width="96"
          height="96"
          alt="Unutma"
          class="h-20 w-20 shrink-0 rounded-[22%] shadow-brand ring-1 ring-black/[0.07] sm:h-24 sm:w-24 dark:ring-white/10"
          decoding="async"
        />
        <div class="min-w-0 flex-1">
          <p class="brand-wordmark brand-wordmark-lg">Unutma</p>
          <p class="brand-peace mt-2 text-base md:text-lg">
            {u.peace}
          </p>
          <h1 class="brand-hero-title mt-5 max-w-3xl text-4xl md:text-5xl lg:text-[3.15rem]">
            {u.heroTitle}
          </h1>
          <p class="mt-4 max-w-2xl text-lg font-normal leading-relaxed text-gray-600 dark:text-gray-400">
            {u.heroBody}
          </p>
        </div>
      </div>

      <div class="mt-10 flex max-w-2xl flex-col gap-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <a
            href="#get-app"
            class="inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-xl bg-brand px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand/25 ring-1 ring-brand/20 transition motion-safe:transition-transform motion-safe:hover:-translate-y-0.5 focus-visible:outline focus-visible:ring-2 focus-visible:ring-brand/50 focus-visible:ring-offset-2 dark:ring-offset-gray-950 sm:w-auto sm:justify-center"
          >
            <svg class="h-5 w-5 shrink-0 opacity-95" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              />
            </svg>
            {u.heroCtaPrimary}
          </a>
          <a
            href="/blog/unutma-app-complete-feature-guide/"
            class="inline-flex min-h-[52px] w-full items-center justify-center gap-2 rounded-xl border border-gray-300 bg-white px-6 py-3.5 text-base font-semibold text-gray-900 shadow-sm ring-1 ring-black/5 transition hover:bg-gray-50 focus-visible:outline focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:ring-offset-2 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100 dark:ring-white/10 dark:hover:bg-gray-800 sm:w-auto sm:justify-center"
          >
            <svg class="h-5 w-5 shrink-0 opacity-90" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"
              />
              <path stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M14 2v6h6M8 13h8M8 17h8" />
            </svg>
            {u.heroCtaSecondary}
          </a>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">
          <a
            href="/blog/"
            class="font-medium text-brand underline-offset-4 hover:underline dark:text-indigo-400"
            >{u.readBlog}</a
          >
        </p>
        <div id="get-app" class="flex scroll-mt-24 flex-col gap-3 border-t border-gray-200/80 pt-6 dark:border-gray-700/80">
          <p
            class="text-xs font-semibold uppercase tracking-[0.12em] text-gray-500 dark:text-gray-400"
          >
            {u.getApp}
          </p>
          <StoreBadgeRow emphasis="secondary" />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="section-title text-3xl md:text-[2rem]">{u.latest}</h2>
    <p class="mt-1 text-gray-600 dark:text-gray-400">
      {u.latestSub}
    </p>
    <div class="mt-10 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        latest.length ? (
          latest.map((post) => <BlogCard post={post} />)
        ) : (
          <p class="text-gray-500 md:col-span-2 dark:text-gray-400">
            {u.noPosts}{' '}
            <code class="rounded bg-gray-100 px-1 text-sm dark:bg-gray-800">src/content/blog/</code>{' '}
            {u.noPostsHint}
          </p>
        )
      }
    </div>
    <p class="mt-10 text-center">
      <a
        href="/blog/"
        class="font-medium text-brand hover:underline dark:text-indigo-400">{u.viewAll}</a
      >
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-16">
    <h2 class="section-title text-3xl md:text-[2rem]">{u.why}</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        whyCards.map((card, i) => (
          <div
            class:list={[
              'rounded-xl border border-gray-100 bg-white p-5 pl-4 shadow-sm dark:border-gray-800 dark:bg-gray-900/40',
              'border-l-4',
              card.border,
            ]}
          >
            <div class="flex gap-4">
              <span
                class:list={[
                  'flex h-11 w-11 shrink-0 items-center justify-center rounded-xl',
                  card.iconBg,
                ]}
              >
                {card.icon === 'offline' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M3 3l18 18M8.5 8.5a4 4 0 016.5 6.5M8 12a4 4 0 014-4m4 4a4 4 0 01-4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                    />
                    <path
                      d="M2 12h2m16 0h2M12 2v2m0 16v2"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      opacity="0.35"
                    />
                  </svg>
                )}
                {card.icon === 'shield' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M12 3l8 4v5c0 5-3.5 9-8 10-4.5-1-8-5-8-10V7l8-4z"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M9 12l2 2 4-4"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {card.icon === 'gift' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M12 8h9v4H3V8h9zM12 8V5a2 2 0 10-4 0v3M12 8V5a2 2 0 114 0v3"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M7 12v9h10v-9"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {card.icon === 'globe' && (
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75" />
                    <path
                      d="M3 12h18M12 3a15 15 0 000 18M12 3a15 15 0 010 18"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
              </span>
              <div class="min-w-0">
                <p class="text-[0.65rem] font-bold uppercase tracking-wider text-gray-400 dark:text-gray-500">
                  {String(i + 1).padStart(2, '0')}
                </p>
                <h3 class="font-display text-lg font-semibold text-gray-900 dark:text-gray-100">
                  {card.title}
                </h3>
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{card.body}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-20">
    <NewsletterForm />
  </section>
</BaseLayout>
