---
import { t } from '../i18n/ui';
import StoreBadgeRow from './StoreBadgeRow.astro';

const u = t().appBanner;
---

<aside
  class="my-8 rounded-xl border border-indigo-200 bg-gradient-to-r from-indigo-50 to-cyan-50 p-6 dark:border-indigo-900/60 dark:from-indigo-950/50 dark:to-cyan-950/40"
>
  <h3 class="mb-2 text-lg font-semibold text-gray-900 dark:text-gray-100">
    {u.title}
  </h3>
  <p class="mb-4 text-gray-600 dark:text-gray-400">
    {u.body}
  </p>
  <StoreBadgeRow />
</aside>
