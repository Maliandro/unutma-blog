---
/**
 * Store links as plain text (no badge graphics).
 */
import { t } from '../i18n/ui';

interface Props {
  class?: string;
  /** Slightly quieter under a primary CTA */
  emphasis?: 'default' | 'secondary';
}

const { class: className, emphasis = 'default' } = Astro.props;
const u = t();

const playStoreUrl =
  import.meta.env.PUBLIC_PLAY_STORE_URL ??
  'https://play.google.com/store/apps/details?id=com.mehmet.unutma';
const appStoreUrl =
  import.meta.env.PUBLIC_APP_STORE_URL ??
  'https://apps.apple.com/us/app/unutma-peace-of-mind/id6758889495';

const linkClass =
  emphasis === 'secondary'
    ? 'text-sm font-semibold text-brand hover:underline dark:text-indigo-400'
    : 'text-base font-semibold text-brand hover:underline dark:text-indigo-400';
---

<div class:list={['flex flex-wrap items-center gap-x-6 gap-y-2', className]}>
  <a
    href={playStoreUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[linkClass, 'rounded-md py-1 focus:outline-none focus:ring-2 focus:ring-brand/40']}
  >
    {u.footer.googlePlay}
  </a>
  <a
    href={appStoreUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[linkClass, 'rounded-md py-1 focus:outline-none focus:ring-2 focus:ring-brand/40']}
  >
    {u.footer.appStore}
  </a>
</div>
