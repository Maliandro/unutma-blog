---
/**
 * Store links as plain text (no badge graphics).
 */
import { t } from '../i18n/ui';

interface Props {
  class?: string;
  /** Slightly quieter under a primary CTA */
  emphasis?: 'default' | 'secondary';
}

const { class: className, emphasis = 'default' } = Astro.props;
const u = t();

const playStoreUrl =
  import.meta.env.PUBLIC_PLAY_STORE_URL ??
  'https://play.google.com/store/apps/details?id=com.mehmet.unutma';
const appStoreUrl =
  import.meta.env.PUBLIC_APP_STORE_URL ??
  'https://apps.apple.com/us/app/unutma-peace-of-mind/id6758889495';

const playClass =
  emphasis === 'secondary'
    ? 'inline-flex min-h-[44px] items-center justify-center rounded-full bg-[#01875f]/15 px-5 py-2.5 text-sm font-bold text-[#016b4c] shadow-sm ring-1 ring-[#01875f]/25 hover:bg-[#01875f]/25 focus:outline-none focus:ring-2 focus:ring-[#01875f]/40 dark:bg-emerald-500/15 dark:text-emerald-300 dark:ring-emerald-500/30 dark:hover:bg-emerald-500/25'
    : 'inline-flex min-h-[48px] items-center justify-center rounded-full bg-[#01875f]/15 px-6 py-3 text-base font-bold text-[#016b4c] shadow-md ring-1 ring-[#01875f]/30 hover:bg-[#01875f]/25 focus:outline-none focus:ring-2 focus:ring-[#01875f]/40 dark:bg-emerald-500/15 dark:text-emerald-300 dark:ring-emerald-500/35 dark:hover:bg-emerald-500/25';

const appleClass =
  emphasis === 'secondary'
    ? 'inline-flex min-h-[44px] items-center justify-center rounded-full bg-gray-900 px-5 py-2.5 text-sm font-bold text-white shadow-sm ring-1 ring-black/10 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white'
    : 'inline-flex min-h-[48px] items-center justify-center rounded-full bg-gray-900 px-6 py-3 text-base font-bold text-white shadow-md ring-1 ring-black/10 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-gray-400 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-white';
---

<div class:list={['flex flex-wrap items-center gap-4', className]}>
  <a href={playStoreUrl} target="_blank" rel="noopener noreferrer" class={playClass}>
    {u.footer.googlePlay}
  </a>
  <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class={appleClass}>
    {u.footer.appStore}
  </a>
</div>
