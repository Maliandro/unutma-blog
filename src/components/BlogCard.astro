---
import type { CollectionEntry } from 'astro:content';
import { DATE_LOCALE } from '../i18n/locales';
import { coverForSlug } from '../utils/covers';
import { t } from '../i18n/ui';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const date = post.data.pubDate;
const coverSrc = post.data.image ?? coverForSlug(post.slug);
const coverAlt = post.data.imageAlt ?? post.data.title;
const u = t();
const postHref = `/blog/${post.slug}/`;
---

<article
  class="group flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition hover:border-indigo-100 hover:shadow-md dark:border-gray-800 dark:bg-gray-900 dark:hover:border-indigo-900/80"
>
  <a
    href={postHref}
    class="relative aspect-[1200/630] w-full shrink-0 overflow-hidden bg-gray-100 dark:bg-gray-800/90"
  >
    <img
      src={coverSrc}
      alt={coverAlt}
      width="1200"
      height="630"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover object-center motion-safe:transition motion-safe:duration-300 motion-safe:group-hover:scale-[1.02] ring-1 ring-inset ring-black/[0.06] dark:ring-white/10"
    />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <time
      class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400"
      datetime={date.toISOString()}
    >
      {
        date.toLocaleDateString(DATE_LOCALE, {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })
      }
    </time>
    <h2
      class="font-display mt-2 text-xl font-semibold tracking-tight text-gray-900 group-hover:text-brand dark:text-gray-100 dark:group-hover:text-indigo-400"
    >
      <a href={postHref} class="focus:outline-none focus:ring-2 focus:ring-brand/40 rounded">
        {post.data.title}
      </a>
    </h2>
    <p class="mt-2 flex-1 text-gray-600 line-clamp-3 dark:text-gray-400">{post.data.description}</p>
    {
      post.data.tags?.length ? (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.slice(0, 4).map((tag) => (
            <a
              href={`/blog/tags/${encodeURIComponent(tag)}/`}
              class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs text-indigo-700 hover:bg-indigo-100 dark:bg-indigo-950/80 dark:text-indigo-300 dark:hover:bg-indigo-900"
            >
              {tag}
            </a>
          ))}
        </div>
      ) : null
    }
    <a
      href={postHref}
      class="mt-4 inline-flex text-sm font-medium text-brand hover:underline dark:text-indigo-400"
    >
      {u.blogCard.readMore}
    </a>
  </div>
</article>
