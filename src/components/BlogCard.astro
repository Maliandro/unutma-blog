---
import type { CollectionEntry } from 'astro:content';
import { coverForSlug } from '../utils/covers';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const date = post.data.pubDate;
const coverSrc = post.data.image ?? coverForSlug(post.slug);
const coverAlt = post.data.imageAlt ?? post.data.title;
---

<article
  class="group flex flex-col overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition hover:border-indigo-100 hover:shadow-md"
>
  <a
    href={`/blog/${post.slug}/`}
    class="relative aspect-[1200/630] w-full shrink-0 overflow-hidden bg-gray-100"
  >
    <img
      src={coverSrc}
      alt={coverAlt}
      width="1200"
      height="630"
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
    />
  </a>
  <div class="flex flex-1 flex-col p-6">
  <time
    class="text-xs font-medium uppercase tracking-wide text-gray-500"
    datetime={date.toISOString()}
  >
    {
      date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
    }
  </time>
  <h2
    class="font-display mt-2 text-xl font-semibold tracking-tight text-gray-900 group-hover:text-brand"
  >
    <a href={`/blog/${post.slug}/`} class="focus:outline-none focus:ring-2 focus:ring-brand/40 rounded">
      {post.data.title}
    </a>
  </h2>
  <p class="mt-2 flex-1 text-gray-600 line-clamp-3">{post.data.description}</p>
  {
    post.data.tags?.length ? (
      <div class="mt-4 flex flex-wrap gap-2">
        {post.data.tags.slice(0, 4).map((tag) => (
          <a
            href={`/blog/tags/${encodeURIComponent(tag)}/`}
            class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs text-indigo-700 hover:bg-indigo-100"
          >
            {tag}
          </a>
        ))}
      </div>
    ) : null
  }
  <a
    href={`/blog/${post.slug}/`}
    class="mt-4 inline-flex text-sm font-medium text-brand hover:underline"
  >
    Read more →
  </a>
  </div>
</article>
